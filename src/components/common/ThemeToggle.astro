---
// Theme toggle component with FOUC prevention
import siteConfig from '@/site.config';

const defaultMode = siteConfig.theme.defaultColorMode;
---

<button
  id="theme-toggle"
  class="theme-toggle glass-button"
  type="button"
  aria-label="Toggle color theme"
  title="Toggle color theme"
  data-default-mode={defaultMode}
>
  <svg class="icon icon-sun" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <svg class="icon icon-moon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
  <svg class="icon icon-system" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
    <line x1="8" y1="21" x2="16" y2="21"></line>
    <line x1="12" y1="17" x2="12" y2="21"></line>
  </svg>
</button>

<style>
  .theme-toggle {
    position: relative;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .theme-toggle:hover {
    background: var(--glass-bg-solid);
  }

  .icon {
    position: absolute;
    transition: opacity var(--transition-base), transform var(--transition-base);
    width: 20px;
    height: 20px;
  }

  /*
    Icons track the *selected* preference (data-theme-mode), not the resolved
    appearance (data-theme). In "system" mode data-theme is light/dark but the
    monitor icon must still show — keying on data-theme-mode keeps them in sync.
  */
  .icon-sun,
  .icon-moon {
    opacity: 0;
    transform: scale(0.8) rotate(-180deg);
  }

  /* Fallback before the mode attribute is set: show the system icon. */
  .icon-system {
    opacity: 1;
    transform: scale(1) rotate(0);
  }

  /* System mode */
  [data-theme-mode="system"] .icon-system {
    opacity: 1;
    transform: scale(1) rotate(0);
  }

  [data-theme-mode="system"] .icon-sun,
  [data-theme-mode="system"] .icon-moon {
    opacity: 0;
    transform: scale(0.8) rotate(180deg);
  }

  /* Light mode */
  [data-theme-mode="light"] .icon-sun {
    opacity: 1;
    transform: scale(1) rotate(0);
  }

  [data-theme-mode="light"] .icon-moon,
  [data-theme-mode="light"] .icon-system {
    opacity: 0;
    transform: scale(0.8) rotate(180deg);
  }

  /* Dark mode */
  [data-theme-mode="dark"] .icon-moon {
    opacity: 1;
    transform: scale(1) rotate(0);
  }

  [data-theme-mode="dark"] .icon-sun,
  [data-theme-mode="dark"] .icon-system {
    opacity: 0;
    transform: scale(0.8) rotate(180deg);
  }

  /* Keyboard focus */
  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .icon {
      transition: opacity var(--transition-base);
    }
  }
</style>

<script>
  // Theme toggle functionality
  const toggle = document.getElementById('theme-toggle');
  const themes = ['system', 'light', 'dark'];

  // Fallback when the visitor has no saved preference, from site.config.
  const defaultMode = toggle?.dataset.defaultMode ?? 'system';

  // localStorage can throw (Safari "block all cookies", private mode, sandboxed
  // iframes). Wrap every access so a failure degrades gracefully instead of
  // breaking the toggle.
  function safeGet(key: string): string | null {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }
  function safeSet(key: string, value: string) {
    try {
      localStorage.setItem(key, value);
    } catch {
      /* storage unavailable — preference simply won't persist */
    }
  }

  function prefersDark(): boolean {
    try {
      return window.matchMedia('(prefers-color-scheme: dark)').matches;
    } catch {
      return false;
    }
  }

  function getThemePreference(): string {
    const stored = safeGet('theme');
    if (stored && themes.includes(stored)) {
      return stored;
    }
    return themes.includes(defaultMode) ? defaultMode : 'system';
  }

  // Keep the <meta name="theme-color"> in sync with the resolved appearance so
  // mobile browser chrome matches the page.
  function updateThemeColor(resolved: string) {
    const meta = document.getElementById('theme-color-meta');
    if (meta) meta.setAttribute('content', resolved === 'dark' ? '#0b0f19' : '#f5f6f9');
  }

  // `mode` is the selected preference ('system' | 'light' | 'dark'). We persist
  // it verbatim — including 'system' — so a site whose defaultColorMode is
  // light/dark doesn't silently revert the visitor's "system" choice on reload.
  function applyTheme(mode: string) {
    const root = document.documentElement;
    const resolved = mode === 'system' ? (prefersDark() ? 'dark' : 'light') : mode;

    root.setAttribute('data-theme', resolved);
    root.setAttribute('data-theme-mode', mode);
    safeSet('theme', mode);
    updateThemeColor(resolved);
  }

  function cycleTheme() {
    const current = getThemePreference();
    const currentIndex = themes.indexOf(current);
    const nextIndex = (currentIndex + 1) % themes.length;
    const nextTheme = themes[nextIndex];

    applyTheme(nextTheme);

    // Announce for screen readers. The live region is inserted empty first, then
    // its text is set on the next tick — many screen readers only announce
    // changes to a region that already existed in the DOM.
    const announcement = document.createElement('div');
    announcement.setAttribute('role', 'status');
    announcement.setAttribute('aria-live', 'polite');
    announcement.className = 'sr-only';
    document.body.appendChild(announcement);

    requestAnimationFrame(() => {
      announcement.textContent = `Theme changed to ${nextTheme}`;
    });

    setTimeout(() => {
      announcement.remove();
    }, 1000);
  }

  // Set up event listener
  toggle?.addEventListener('click', cycleTheme);

  // Re-resolve when the OS preference changes while in "system" mode.
  try {
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if (getThemePreference() === 'system') {
        applyTheme('system');
      }
    });
  } catch {
    /* matchMedia unavailable — ignore */
  }
</script>