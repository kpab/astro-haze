---
import { Picture as AstroPicture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  widths,
  sizes,
  loading = 'lazy',
  fetchpriority,
  class: className,
} = Astro.props;

// Imported assets (ImageMetadata) are optimized to AVIF first, then WebP.
// Plain string paths (public/ or remote) are rendered as-is.
const isLocalAsset = typeof src !== 'string';
---

{
  isLocalAsset ? (
    <AstroPicture
      src={src as ImageMetadata}
      alt={alt}
      formats={['avif', 'webp']}
      widths={widths}
      sizes={sizes}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
    />
  ) : (
    <img
      src={src as string}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      class={className}
    />
  )
}
