---
import '@/styles/global.css';
import Seo from '@/components/common/Seo.astro';
import AuroraBackground from '@/components/common/AuroraBackground.astro';
import ThemeToggle from '@/components/common/ThemeToggle.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO: title, description, canonical, Open Graph, Twitter, JSON-LD -->
    <Seo
      title={props.title}
      description={props.description}
      ogImage={props.ogImage}
      noIndex={props.noIndex}
      article={props.article}
    />

    <!-- Theme Script (FOUC Prevention) -->
    <script is:inline>
      // Apply theme immediately to prevent FOUC
      (function() {
        const stored = localStorage.getItem('theme');
        const root = document.documentElement;

        if (stored === 'light' || stored === 'dark') {
          root.setAttribute('data-theme', stored);
        } else if (!stored || stored === 'system') {
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (prefersDark) {
            root.setAttribute('data-theme', 'dark');
          }
        }
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Skip to content link -->
    <a href="#main" class="skip-link">Skip to content</a>

    <!-- Aurora Background -->
    <AuroraBackground intensity="medium" animated={true} />

    <!-- Main Layout -->
    <slot />

    <!-- Theme Toggle (can be positioned by parent) -->
    <div id="theme-toggle-container">
      <ThemeToggle />
    </div>
  </body>
</html>

<style>
  #theme-toggle-container {
    position: fixed;
    bottom: var(--space-xl);
    right: var(--space-xl);
    z-index: var(--z-sticky);
  }

  @media (max-width: 768px) {
    #theme-toggle-container {
      bottom: var(--space-lg);
      right: var(--space-lg);
    }
  }

  /* Smooth color transitions on theme change */
  html {
    transition: background-color var(--transition-base), color var(--transition-base);
  }
</style>