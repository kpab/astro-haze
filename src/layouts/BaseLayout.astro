---
import '@/styles/global.css';
import siteConfig from '@/site.config';
import Seo from '@/components/common/Seo.astro';
import AuroraBackground from '@/components/common/AuroraBackground.astro';
import ThemeToggle from '@/components/common/ThemeToggle.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon & app icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0b0f19" />

    <!-- SEO: title, description, canonical, Open Graph, Twitter, JSON-LD -->
    <Seo
      title={props.title}
      description={props.description}
      ogImage={props.ogImage}
      noIndex={props.noIndex}
      article={props.article}
    />

    <!-- Theme Script (FOUC Prevention) -->
    <script
      is:inline
      set:html={`(function(){
        var stored = localStorage.getItem('theme');
        var fallback = ${JSON.stringify(siteConfig.theme.defaultColorMode)};
        var mode = (stored === 'light' || stored === 'dark')
          ? stored
          : (fallback === 'light' || fallback === 'dark')
            ? fallback
            : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', mode);
      })();`}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Skip to content link -->
    <a href="#main" class="skip-link">Skip to content</a>

    <!-- Aurora Background -->
    <AuroraBackground intensity="medium" animated={true} />

    <!-- Main Layout -->
    <slot />

    <!-- Theme Toggle (can be positioned by parent) -->
    {
      siteConfig.theme.showThemeToggle && (
        <div id="theme-toggle-container">
          <ThemeToggle />
        </div>
      )
    }
  </body>
</html>

<style>
  #theme-toggle-container {
    position: fixed;
    bottom: var(--space-xl);
    right: var(--space-xl);
    z-index: var(--z-sticky);
  }

  @media (max-width: 768px) {
    #theme-toggle-container {
      bottom: var(--space-lg);
      right: var(--space-lg);
    }
  }

  /* Smooth color transitions on theme change */
  html {
    transition: background-color var(--transition-base), color var(--transition-base);
  }
</style>