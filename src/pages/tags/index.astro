---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import GlassPanel from '@/components/common/GlassPanel.astro';
import Container from '@/components/ui/Container.astro';
import { getPublishedPosts, collectTags } from '@/lib/posts';

const posts = await getPublishedPosts();
const tags = collectTags(posts);
const maxCount = tags.reduce((m, t) => Math.max(m, t.count), 1);
---

<BaseLayout title="Tags" description="Browse all topics on the blog by tag.">
  <Header />

  <main id="main" class="main-content">
    <section class="section">
      <Container size="md">
        <header class="tags-header">
          <h1 class="tags-title">Tags</h1>
          <p class="tags-subtitle">Browse posts by topic.</p>
        </header>

        {
          tags.length === 0 ? (
            <GlassPanel variant="default" padding="xl" className="empty">
              <p>No tags yet.</p>
            </GlassPanel>
          ) : (
            <GlassPanel variant="solid" padding="xl">
              <ul class="tag-cloud">
                {tags.map(({ tag, count }) => (
                  <li>
                    <a
                      class="tag-cloud__item"
                      href={`/tags/${tag
                        .toLowerCase()
                        .trim()
                        .replace(/[^a-z0-9]+/g, '-')
                        .replace(/^-+|-+$/g, '')}`}
                      style={`--weight: ${0.85 + (count / maxCount) * 0.6}`}
                    >
                      <span class="tag-cloud__hash">#</span>
                      {tag}
                      <span class="tag-cloud__count">{count}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </GlassPanel>
          )
        }
      </Container>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main-content {
    min-height: 100vh;
    padding-top: var(--space-2xl);
  }

  .section {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .tags-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .tags-title {
    font-size: var(--text-4xl);
    font-weight: 800;
  }

  .tags-subtitle {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .tag-cloud {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .tag-cloud__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-full);
    border: 1px solid var(--glass-border);
    color: var(--color-text);
    text-decoration: none;
    font-size: calc(var(--text-base) * var(--weight, 1));
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .tag-cloud__item:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-glass);
  }

  .tag-cloud__item:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .tag-cloud__hash {
    color: var(--color-accent);
  }

  .tag-cloud__count {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--glass-bg);
    border-radius: var(--radius-full);
    padding: 0 var(--space-xs);
    min-width: 1.4em;
    text-align: center;
  }

  .empty {
    text-align: center;
  }
</style>
